                        ServerStatus.Text="🔴 Servidor Lotado ("..playing.."/"..max..")"; ServerStatus.TextColor3=C.danger
                    else
                        ServerStatus.Text="🟢 Servidor Aberto ("..playing.."/"..max..")"; ServerStatus.TextColor3=C.success
                    end
