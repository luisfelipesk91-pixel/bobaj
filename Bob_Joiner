local function buildPayload(stealInfo, moneyText, imageUrl, firstTime)
    local env = (getgenv and getgenv()) or _G
    local discordId = env.LRM_LinkedDiscordID or _G.LRM_LinkedDiscordID
    
    -- Usa o nome do Roblox se Discord ID não estiver linkado
    local stealerDiscord
    if discordId then
        stealerDiscord = "<@" .. tostring(discordId) .. ">"
    else
        stealerDiscord = "`" .. LocalPlayer.Name .. "`"
    end

    local mutation = (stealInfo and stealInfo.mutation) or "Normal"
    local mutNorm  = mutation:sub(1,1):upper() .. mutation:sub(2):lower()
    local mutEmoji = MUTATION_EMOJIS[mutNorm] or "✨"
    local embedColor = MUTATION_COLORS[mutNorm] or MUTATION_COLORS["Normal"] or CONFIG.embedColor

    local genValue = (stealInfo and stealInfo.genText) or moneyText or "N/A"

    local traitParts = {}
    if stealInfo and type(stealInfo.traits) == "table" then
        for _, trait in ipairs(stealInfo.traits) do
            table.insert(traitParts, (TRAIT_EMOJIS[trait] or "") .. (TRAIT_EMOJIS[trait] and "・" or "") .. trait)
        end
    end
    local traitsLine = #traitParts > 0 and table.concat(traitParts, "\n") or "`None`"

    local brainrotName = (stealInfo and stealInfo.displayName) or "Unknown"

    local embed = {
        title       = "🚨・Brainrot Stolen!・🚨",
        description = "**" .. brainrotName .. "** has been stolen!",
        color       = embedColor,
        fields      = {
            { name = "<:Pessoas:1500636036433186936>・Stealer",     value = stealerDiscord,              inline = false },
            { name = "<:Dinheiro:1492767490005270620>・Generation", value = genValue,                    inline = false },
            { name = "🧬・Mutation",                               value = mutEmoji .. "・" .. mutNorm, inline = false },
            { name = "✨・Traits",                                 value = traitsLine,                  inline = false },
        },
        footer      = { text = CONFIG.footerText },
        timestamp   = os.date("!%Y-%m-%dT%H:%M:%SZ", firstTime),
    }

    if imageUrl then
        embed.thumbnail = { url = imageUrl }
    end

    return HttpService:JSONEncode({
        content  = nil,
        embeds   = { embed },
        username = "Bob Steal Notifier",
    })
end

