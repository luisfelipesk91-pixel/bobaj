local function formatSeconds(s)
    if s == math.huge then return "∞ Lifetime" end
    if s <= 0 then return "Expirado" end
    local h = math.floor(s/3600); s = s%3600; local m = math.floor(s/60); s = s%60
    local p = {}; if h>0 then p[#p+1]=h.."h" end; if m>0 then p[#p+1]=m.."m" end; if s>0 or #p==0 then p[#p+1]=s.."s" end
    return table.concat(p," ")
end

local function parseBestBrainrot(title, description)
    if not description or description:gsub("%s","") == "" then return tostring(title or "Brainrot"), "?", 0 end
    local bestName, bestVal, bestNum = nil, "?", 0
    local function toNumber(rawVal)
        if not rawVal then return 0 end
        local n, suffix = rawVal:match("^([%d%.]+)([A-Za-z]?)$")
        if not n then return 0 end
        local num = tonumber(n) or 0; local s = suffix:upper()
        if s=="K" then num=num*1e3 elseif s=="M" then num=num*1e6 elseif s=="B" then num=num*1e9 elseif s=="T" then num=num*1e12 elseif s=="Q" or s=="QA" then num=num*1e15 end
        return num
    end
    for line in (description.."\n"):gmatch("([^\n]+)\n") do
        line = line:gsub("^%s*(.-)%s*$", "%1")
        local rawName, rawVal = line:match("%dx%s+(.-)%s+%(%$([%d%.]+[A-Za-z]?)/?")
        if not rawName then rawName, rawVal = line:match("%[.-%]%s+(.-)%s+%(%$([%d%.]+[A-Za-z]?)/?" ) end
        if not rawName then rawName, rawVal = line:match("^(.-)%s+%(%$([%d%.]+[A-Za-z]?)/?" ) end
        if rawName and rawVal then
            local num = toNumber(rawVal)
            if num > bestNum then bestNum=num; bestName=rawName:gsub("^%s*(.-)%s*$","%1"); bestVal="$"..rawVal.."/s" end
        end
    end
    if not bestName or bestName=="" then return tostring(title or "Brainrot"), description:sub(1,30)..(#description>30 and "..." or ""), 0 end
    return bestName, bestVal, bestNum
end

local function validateKey(key)
    STATE.hwid = getHWID()
    local url = API_BASE.."/api/auth"
    local body
    for i=1, 2 do body = httpPostJson(url, jsonEncode({key=key, hwid=STATE.hwid})); if body and body ~= "" then break end; task.wait(1.5) end
    if not body then return false, "⚠️ Sem conexão com a API." end
    if body:lower():find("acesso negado") or body:lower():find("access denied") then return false, "🛡️ IP Bloqueado. Aguarde 10 min." end
    if body:find("Chave nao existe") then return false, "❌ Key inválida." end
    if body:find("HWID invalido") then return false, "🔒 HWID inválido." end
    if body:find("Chave pausada") then return false, "⏸️ Key pausada." end
    if body:find("Chave expirada") then return false, "⌛ Key expirada." end
    local data = jsonDecode(body)
    if data and data.ok then
        STATE.key=key; STATE.active=true
        local tl = data.timeLeft
        if tl == "Infinity" or tl == math.huge or data.isLifetime then
            STATE.time_left_sec = math.huge
        else
            STATE.time_left_sec = math.floor(tonumber(tl or 0)/1000)
        end
        STATE.sessionId = LocalPlayer.Name.."_"..tostring(math.random(100000,999999))
        pcall(function() if writefile then writefile("bob_key.txt", key) end end)
        return true
    elseif data and data.error then
        return false, data.error
    end
    return false, "❌ Key inválida ou expirada."
end

