        -- Botão JOIN único (tamanho original)
        local JoinBtn=Instance.new("TextButton",LogItem); JoinBtn.Size=UDim2.new(0,62,0,50); JoinBtn.Position=UDim2.new(1,-70,0.5,-25); JoinBtn.BackgroundColor3=C.accent; JoinBtn.Text="JOIN"; JoinBtn.TextColor3=Color3.new(1,1,1); JoinBtn.Font=Enum.Font.GothamBold; JoinBtn.TextSize=13; JoinBtn.AutoButtonColor=false; corner(JoinBtn,8)
        JoinBtn.MouseEnter:Connect(function() tween(JoinBtn,0.15,{BackgroundColor3=C.accentGlow}):Play() end)
        JoinBtn.MouseLeave:Connect(function() tween(JoinBtn,0.15,{BackgroundColor3=C.accent}):Play() end)
        
        if jobId~="" then
            JoinBtn.MouseButton1Click:Connect(function() 
                playClick()
                SmartJoin(jobId,ServerStatus)
            end)
            task.spawn(function()
                task.wait(0.5)
                
                -- Auto Join: verifica ANTES de checar o cache do servidor
                local shouldAutoJoin = false
                if AutoJoinEnabled then 
                    shouldAutoJoin = true
                elseif AutoJoinDuelEnabled and name:find("⚔️") then
                    shouldAutoJoin = true
                end
                
                -- Se Auto Join estiver ativo, entra imediatamente
                if shouldAutoJoin then
                    SmartJoin(jobId,ServerStatus)
