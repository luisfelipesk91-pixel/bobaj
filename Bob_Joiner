                local Gear=(typeof(rawGear)=="string" and rawGear~="" and not rawGear:match("^#%x+$") and not tonumber(rawGear)) and rawGear or (Hit.Parent and Hit.Parent.Name or "Unknown")
                local Char=Hit.Parent and Hit.Parent.Parent; if not Char then return end
                local Plr=Players:GetPlayerFromCharacter(Char)
                local Attacker=Plr and Plr.Name or Char.Name
                if Attacker~="Unknown" and Attacker~=LocalPlayer.Name then
                    QueueGriefNotification(Attacker.." used "..Gear.." on you!",Attacker,Gear)
                end
            end)
        end
    end

    if Debug.Enabled then Notify(Debug.Griefer,Debug.Victim,Debug.Item,Debug.Autojoiner,Debug.StealInfo) end
end)

    local function endSession(reason)
        if not STATE.active then return end; STATE.active=false; STATE.key=""; STATE.hwid=""; STATE.time_left_sec=0
        pcall(function() if writefile then writefile("bob_key.txt","") end end)
        ScreenGui:Destroy(); CreateLoginUI(reason)
    end

    task.spawn(function() while STATE.active do task.wait(1); if STATE.time_left_sec~=math.huge then if STATE.time_left_sec>0 then STATE.time_left_sec-=1 end; TimerTxt.Text=formatSeconds(STATE.time_left_sec); KeyTimeLbl.Text="Key: "..formatSeconds(STATE.time_left_sec); if STATE.time_left_sec<300 then tween(TimerTxt,0.5,{TextColor3=C.danger}):Play() elseif STATE.time_left_sec<3600 then tween(TimerTxt,0.5,{TextColor3=C.warning}):Play() end; if STATE.time_left_sec<=0 then endSession("⌛ Sua key expirou."); return end end end end)
    task.spawn(function()
        local failCount=0
        while STATE.active do
            task.wait(45); if not STATE.active then return end
            local body = httpPostJson(API_BASE.."/api/auth", jsonEncode({key=STATE.key, hwid=STATE.hwid}))
            if not body or body=="" then 
                failCount+=1; if failCount>=3 then endSession("⚠️ Falha de conexão. Verifique sua internet."); return end; continue 
            end
            failCount=0; local data=jsonDecode(body)
            if not data or not data.ok then
                local reason="⌛ Sua key expirou."
                if data and data.error then reason = data.error end
                endSession(reason); return
            else 
                local tl = data.timeLeft
                if tl == "Infinity" or tl == math.huge or data.isLifetime then
                    STATE.time_left_sec = math.huge
                else
                    STATE.time_left_sec = math.floor(tonumber(tl or 0)/1000)
                end
            end
        end
    end)
    task.spawn(function() 
        while STATE.active do 
            httpPostJson(API_BASE.."/api/presence", jsonEncode({key=STATE.key, name=LocalPlayer.Name, jobId=game.JobId}))
            task.wait(20+math.random(1,5)) 
        end 
    end)
    task.spawn(function() 
        while STATE.active do 
            local body = httpGet(API_BASE.."/api/online")
            if body and body ~= "" then
                local data = jsonDecode(body)
                if data and data.online then RefreshUserList(data.online) end
            end
            task.wait(15+math.random(1,5)) 
        end 
    end)

    local lastLatestId=""
    local startTime=os.time()
    task.spawn(function()
        setStatus("Online",C.success)
        -- clearLogsAPI() -- Comentado para não limpar logs de outros ao entrar
        while STATE.active do
            local body = httpGet(API_BASE.."/api/latest?key="..urlEncode(STATE.key).."&secret="..SCRIPT_SECRET)
            if body and body~="" then
                local data = jsonDecode(body)
                if data and data.id and data.id ~= lastLatestId and (os.time()-startTime) > 3 then
                    lastLatestId = data.id
                    local name = tostring(data.brainrot or data.name or "Unknown")
                    local value = tostring(data.value or "0")
                    local owner = tostring(data.owner or "Unknown")
                    local jobId = tostring(data.jobId or "")
                    local players = data.players or "?"
                    local maxPlayers = data.maxPlayers or "?"
                    local inDuel = data.inDuel or false
                    
                    -- Adiciona ⚔️ ao nome se for duel
                    if inDuel then
