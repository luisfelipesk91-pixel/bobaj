    local function CreateLogEntry(jobId, name, genStr, numVal, players, maxPlayers, inDuel)
        -- 1️⃣ APLICA GEN MÍNIMO GLOBAL (prioridade máxima)
        if numVal < GlobalGenMin then return end
        
        -- 2️⃣ Verifica se há algum filtro ativo
        local hasActiveFilters = false
        for brainrotName, filter in pairs(BrainrotFilters) do
            if filter.enabled then
                hasActiveFilters = true
                break
            end
        end
        
        -- 3️⃣ Se houver filtros ativos, verifica se este brainrot está na lista
        if hasActiveFilters then
            local matchedFilter = false
            local low = name:lower()
            
            for brainrotName, filter in pairs(BrainrotFilters) do
                if filter.enabled then
                    -- Verifica se o nome do brainrot contém o filtro
                    if name:find(brainrotName) or low:find(brainrotName:lower()) then
                        -- Verifica se atende ao Gen Min individual deste brainrot
                        if numVal >= filter.genMin then
                            matchedFilter = true
                            break
                        end
                    end
                end
            end
            
            -- Se não passou em nenhum filtro ativo, bloqueia a log
            if not matchedFilter then return end
        end
        
        -- 4️⃣ Aplica filtro de valor mínimo global (Settings - compatibilidade)
        if numVal < MinFilterValue then return end
        
        local low=name:lower()
        
        -- 5️⃣ Blacklist e Whitelist originais
        if #Blacklist>0 then for _,bl in ipairs(Blacklist) do if low:find(bl) then return end end end
        if #Whitelist>0 then local f=false; for _,wl in ipairs(Whitelist) do if low:find(wl) then f=true; break end end; if not f then return end end
        if RenderedIDs[jobId] and jobId~="" then return end
        if jobId~="" then RenderedIDs[jobId]=true end
