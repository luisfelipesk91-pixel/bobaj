        if SoundEnabled then BEEP_SOUND.Volume=0.4; pcall(function() BEEP_SOUND:Play() end) end
        local LogItem=Instance.new("Frame",LogPage); LogItem.BackgroundColor3=C.bgItem; LogItem.Size=UDim2.new(1,0,0,68); LogItem.LayoutOrder=-os.time(); corner(LogItem,8)
        local SA=Instance.new("Frame",LogItem); SA.Size=UDim2.new(0,3,0.8,0); SA.Position=UDim2.new(0,0,0.1,0); SA.BackgroundColor3=C.accent; SA.BorderSizePixel=0; corner(SA,3)
        label(LogItem,{text="🧠",size=20,sz=UDim2.new(0,38,1,0),pos=UDim2.new(0,10,0,0),align=Enum.TextXAlignment.Center})
        local NameLbl=label(LogItem,{text=name,font=Enum.Font.GothamBold,size=13,color=C.textPrimary,sz=UDim2.new(1,-160,0,18),pos=UDim2.new(0,52,0,6),wrap=false}); NameLbl.TextTruncate=Enum.TextTruncate.AtEnd
        -- Formata o valor para K/M/B/T
        local formattedValue = formatValue(numVal)
        local ValLbl=label(LogItem,{text=formattedValue,font=Enum.Font.GothamBold,size=12,color=C.gold,sz=UDim2.new(1,-160,0,16),pos=UDim2.new(0,52,0,24),wrap=false}); ValLbl.TextTruncate=Enum.TextTruncate.AtEnd
        
        -- Adiciona informação de players
        local playersText = "🎮 Aguardando..."
        if players and maxPlayers then
            playersText = "🎮 "..tostring(players).."/"..tostring(maxPlayers).." players"
        end
