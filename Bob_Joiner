        inputFrame.Size = UDim2.new(0, 80, 0, 20)
        inputFrame.Position = UDim2.new(1, -85, 0.5, -10)
        inputFrame.BackgroundColor3 = C.bgCard
        corner(inputFrame, 5)
        stroke(inputFrame, C.border, 1)
        
        local input = Instance.new("TextBox", inputFrame)
        input.Size = UDim2.new(1, -8, 1, 0)
        input.Position = UDim2.new(0, 4, 0, 0)
        input.BackgroundTransparency = 1
        input.PlaceholderText = "Ex: 1M"
        input.PlaceholderColor3 = C.textMuted
        input.Text = ""
        input.TextColor3 = C.textPrimary
        input.Font = Enum.Font.Gotham
        input.TextSize = 9
        input.TextXAlignment = Enum.TextXAlignment.Left
        
        -- Inicializa o filtro se não existir
        if not BrainrotFilters[brainrotName] then
            BrainrotFilters[brainrotName] = {enabled = false, genMin = 0}
        end
        
        -- Estado inicial do checkbox
        local function updateCheckbox()
            if BrainrotFilters[brainrotName].enabled then
                checkbox.BackgroundColor3 = C.success
                checkStroke.Color = C.success
                checkIcon.Text = "✓"
            else
                checkbox.BackgroundColor3 = C.bgCard
                checkStroke.Color = C.border
                checkIcon.Text = ""
            end
        end
        
        updateCheckbox()
        
        -- Evento do checkbox
        checkbox.MouseButton1Click:Connect(function()
            playClick()
            BrainrotFilters[brainrotName].enabled = not BrainrotFilters[brainrotName].enabled
            updateCheckbox()
            saveConfig() -- Auto-save quando ativar/desativar
        end)
        
        -- Evento do input
        input.FocusLost:Connect(function()
            local value = parseValue(input.Text)
            BrainrotFilters[brainrotName].genMin = value
            if value > 0 then
                input.Text = formatValue(value):gsub("%$", ""):gsub("/s", "")
            end
            saveConfig() -- Auto-save quando mudar Gen Min
        end)
        
        return item
    end
    
