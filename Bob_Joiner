                end
                
                -- Se não, continua com a verificação normal do servidor
                local alive,playing,max=isServerAliveCached(jobId)
                if alive then
                    -- Atualiza também o label de players com dados reais
                    if PlayersLbl then PlayersLbl.Text="🎮 "..playing.."/"..max.." players" end
                    
